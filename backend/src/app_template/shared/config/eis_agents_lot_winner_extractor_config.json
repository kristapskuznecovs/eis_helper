{
  "agent_type": "lot_winner_extractor",
  "model": "claude-3-haiku-20240307",
  "temperature": 0.0,
  "response_format": {
    "type": "json_schema",
    "json_schema": {
      "name": "lot_winner_extraction",
      "strict": true,
      "schema": {
        "type": "object",
        "properties": {
          "lots": {
            "type": "array",
            "description": "Array of lot information with winners",
            "items": {
              "type": "object",
              "properties": {
                "lot_number": {
                  "type": "integer",
                  "description": "Lot number (1, 2, 3, etc.)"
                },
                "lot_name": {
                  "type": ["string", "null"],
                  "description": "Lot name/description if available"
                },
                "winner_name": {
                  "type": ["string", "null"],
                  "description": "Winner company name for this lot (primary winner if multiple)"
                },
                "winner_price_eur": {
                  "type": ["number", "null"],
                  "description": "Winner's price for this lot in EUR"
                },
                "winner_registration_no": {
                  "type": ["string", "null"],
                  "description": "Winner's registration number if available"
                },
                "participants": {
                  "type": "array",
                  "description": "All participants who bid on this lot with their details",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "Participant company name (must match extracted participant list)"
                      },
                      "suggested_price_eur": {
                        "type": ["number", "null"],
                        "description": "Participant's bid price for THIS lot in EUR"
                      },
                      "is_winner": {
                        "type": "boolean",
                        "description": "Whether this participant won THIS lot"
                      }
                    },
                    "required": ["name", "suggested_price_eur", "is_winner"],
                    "additionalProperties": false
                  }
                }
              },
              "required": ["lot_number", "lot_name", "winner_name", "winner_price_eur", "winner_registration_no", "participants"],
              "additionalProperties": false
            }
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Confidence in lot-winner assignments"
          },
          "notes": {
            "type": ["string", "null"],
            "description": "Any issues or ambiguities encountered"
          }
        },
        "required": ["lots", "confidence", "notes"],
        "additionalProperties": false
      }
    }
  }
}
